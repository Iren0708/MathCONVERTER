<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo.controller.ConverterController"
      alignment="CENTER">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- Заголовок -->
    <Label text="КОНВЕРТЕР ЧИСЕЛ"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Дроби | Десятичные | Проценты"
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <!-- Поле ввода -->
    <VBox spacing="5" prefWidth="300">
        <Label text="Введите число:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="inputField" />
    </VBox>

    <!-- Выбор единиц измерения -->
    <HBox spacing="15" alignment="CENTER">
        <VBox spacing="5">
            <Label text="Из:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="fromComboBox" prefWidth="120"/>
        </VBox>

        <Button fx:id="swapButton"
                text="⇄"
                onAction="#handleSwap"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 20;"
                prefWidth="40"/>

        <VBox spacing="5">
            <Label text="В:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="toComboBox" prefWidth="120"/>
        </VBox>
    </HBox>

    <!-- Кнопка конвертации -->
    <Button fx:id="convertButton"
            text="КОНВЕРТИРОВАТЬ"
            onAction="#handleConvert"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
            prefWidth="300"/>

    <!-- Результат -->
    <VBox spacing="5" alignment="CENTER">
        <Label text="Результат:" style="-fx-font-weight: bold;"/>
        <Label fx:id="resultLabel"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60; -fx-background-color: #f0f0f0; -fx-padding: 10; -fx-background-radius: 5;"
               prefWidth="300"
               alignment="CENTER"/>
    </VBox>

    <!-- Ошибки -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"
           wrapText="true"
           alignment="CENTER"/>

    <!-- Кнопка очистки -->
    <Button text="Очистить все"
            onAction="#handleClear"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 5; -fx-padding: 8 20;"
            prefWidth="300"/>

</VBox>